# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/fantasy_cricket?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# Cricket APIs
CRICAPI_KEY="your-cricapi-key-from-cricapi.com"
CRICKET_DATA_KEY="your-backup-cricketdata-key"

# Puppeteer (for Railway production)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# Mock mode — set to "true" for development without real APIs
MOCK_MODE="true"
